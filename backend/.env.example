APP_ENV=development
DATABASE_URL=postgresql+psycopg://medical_user:medical_password@127.0.0.1:5432/medical_chatbot
POSTGRES_DB=medical_chatbot
POSTGRES_USER=medical_user
POSTGRES_PASSWORD=medical_password
SESSION_SECRET=change-me-for-demo
SESSION_TTL_HOURS=72
CHROMA_PATH=backend/data/rag/chroma
ALLOW_VECTOR_FALLBACK=true
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EXTERNAL_RAG_CHUNKS_PATH=/Users/senolerdem/Downloads/outputs/rag_index/chunks.parquet
EXTERNAL_RAG_INDEX_PATH=/Users/senolerdem/Downloads/outputs/rag_index/index.faiss
EXTERNAL_RAG_INDEX_DIMENSION=768
EXTERNAL_RAG_DOCUMENT_COUNT=196846
# Desteklenen seçenekler: ollama, hf_adapter, hf_local
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434
# Rapor/sunum profili: QLoRA adapter ile merge edilip Q4_K_M quantize edilen model.
LLM_MODEL=medassist-finetuned
LLM_ADAPTER_PATH=/Users/senolerdem/Desktop/MedicalChatbot/backend/model_assets/qlora
# hf_adapter için: base model klasörü
# hf_local için: merge edilmiş tam model klasörü
LLM_BASE_MODEL_PATH=/Users/senolerdem/Desktop/MedicalChatbot/backend/model_assets/merged-medassist-llama3-final
LLM_DEVICE=auto
LLM_MAX_NEW_TOKENS=96
LLM_TIMEOUT_SECONDS=45
LLM_CONTEXT_WINDOW=2048
LLM_KEEP_ALIVE=30m
LLM_TEMPERATURE=0.2
